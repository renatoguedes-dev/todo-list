{
    "env": {
        "browser": true,
        "commonjs": true,
        "es2021": true
    },
    "extends": "airbnb-base",
    "overrides": [
    ],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "linebreak-style": ["error", "windows"],
        "no-console": "off",
        "quotes": ["error", "double"],
        "no-plusplus": ["error", { "allowForLoopAfterthoughts": true }],
        "operator-linebreak": ["error", "after"]
    }

}

